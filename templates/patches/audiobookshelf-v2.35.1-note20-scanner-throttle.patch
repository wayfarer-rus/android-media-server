+++ b/test/server/utils/scandirConcurrency.test.js
@@ -0,0 +1,32 @@
+const { expect } = require('chai')
+const sinon = require('sinon')
+const LibraryFile = require('../../../server/objects/files/LibraryFile')
+const scanUtils = require('../../../server/utils/scandir')
+
+describe('scandir buildLibraryFile concurrency', () => {
+  afterEach(() => {
+    sinon.restore()
+    delete process.env.ABS_SCAN_LIBRARY_FILE_CONCURRENCY
+    delete process.env.ABS_SCAN_LIBRARY_FILE_BATCH_DELAY_MS
+  })
+
+  it('limits concurrent LibraryFile stat work from environment', async () => {
+    process.env.ABS_SCAN_LIBRARY_FILE_CONCURRENCY = '2'
+
+    let active = 0
+    let maxActive = 0
+    sinon.stub(LibraryFile.prototype, 'setDataFromPath').callsFake(async function (filePath, relPath) {
+      active++
+      maxActive = Math.max(maxActive, active)
+      await new Promise((resolve) => setTimeout(resolve, 5))
+      active--
+      this.ino = relPath
+      this.metadata = { path: filePath, relPath }
+    })
+
+    const results = await scanUtils.buildLibraryFile('/library/book', ['1.mp3', '2.mp3', '3.mp3', '4.mp3', '5.mp3'])
+
+    expect(maxActive).to.equal(2)
+    expect(results.map((file) => file.ino)).to.deep.equal(['1.mp3', '2.mp3', '3.mp3', '4.mp3', '5.mp3'])
+  })
+})
