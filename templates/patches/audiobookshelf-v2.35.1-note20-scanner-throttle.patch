index 00000000..34e17fb9
--- /dev/null
+++ b/test/server/scanner/AudioFileScanner.test.js
@@ -0,0 +1,46 @@
+const { expect } = require('chai')
+const sinon = require('sinon')
+const AudioFileScanner = require('../../../server/scanner/AudioFileScanner')
+
+describe('AudioFileScanner', () => {
+  afterEach(() => {
+    sinon.restore()
+    delete process.env.ABS_SCAN_AUDIO_PROBE_CONCURRENCY
+    delete process.env.ABS_SCAN_AUDIO_PROBE_BATCH_DELAY_MS
+  })
+
+  describe('executeMediaFileScans', () => {
+    it('limits concurrent audio probes from environment', async () => {
+      process.env.ABS_SCAN_AUDIO_PROBE_CONCURRENCY = '2'
+
+      let active = 0
+      let maxActive = 0
+      sinon.stub(AudioFileScanner, 'scan').callsFake(async (mediaType, libraryFile) => {
+        active++
+        maxActive = Math.max(maxActive, active)
+        await new Promise((resolve) => setTimeout(resolve, 5))
+        active--
+        return { id: libraryFile.id }
+      })
+
+      const files = Array.from({ length: 5 }, (_, id) => ({ id, metadata: { path: `/tmp/${id}.mp3` } }))
+      const results = await AudioFileScanner.executeMediaFileScans('book', { mediaMetadata: {} }, files)
+
+      expect(maxActive).to.equal(2)
+      expect(results.map((result) => result.id)).to.deep.equal([0, 1, 2, 3, 4])
+    })
+
+    it('keeps filtering failed scans', async () => {
+      process.env.ABS_SCAN_AUDIO_PROBE_CONCURRENCY = '1'
+
+      sinon.stub(AudioFileScanner, 'scan').callsFake(async (mediaType, libraryFile) => {
+        return libraryFile.id === 1 ? null : { id: libraryFile.id }
+      })
+
+      const files = Array.from({ length: 3 }, (_, id) => ({ id, metadata: { path: `/tmp/${id}.mp3` } }))
+      const results = await AudioFileScanner.executeMediaFileScans('book', { mediaMetadata: {} }, files)
+
+      expect(results.map((result) => result.id)).to.deep.equal([0, 2])
+    })
+  })
+})
