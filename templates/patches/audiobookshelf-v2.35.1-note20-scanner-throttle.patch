+++ b/test/server/utils/scannerTuning.test.js
@@ -0,0 +1,45 @@
+const { expect } = require('chai')
+const scannerTuning = require('../../../server/utils/scannerTuning')
+
+describe('scannerTuning', () => {
+  afterEach(() => {
+    delete process.env.TEST_SCANNER_LIMIT
+  })
+
+  describe('parseIntegerEnv', () => {
+    it('returns the default for unset or invalid values', () => {
+      expect(scannerTuning.parseIntegerEnv('TEST_SCANNER_LIMIT', 7, 1, 32)).to.equal(7)
+
+      process.env.TEST_SCANNER_LIMIT = 'not-a-number'
+      expect(scannerTuning.parseIntegerEnv('TEST_SCANNER_LIMIT', 7, 1, 32)).to.equal(7)
+
+      process.env.TEST_SCANNER_LIMIT = '0'
+      expect(scannerTuning.parseIntegerEnv('TEST_SCANNER_LIMIT', 7, 1, 32)).to.equal(7)
+
+      process.env.TEST_SCANNER_LIMIT = '33'
+      expect(scannerTuning.parseIntegerEnv('TEST_SCANNER_LIMIT', 7, 1, 32)).to.equal(7)
+    })
+
+    it('returns integer values inside range', () => {
+      process.env.TEST_SCANNER_LIMIT = '2'
+      expect(scannerTuning.parseIntegerEnv('TEST_SCANNER_LIMIT', 7, 1, 32)).to.equal(2)
+    })
+  })
+
+  describe('mapInBatches', () => {
+    it('limits mapper concurrency and preserves result order', async () => {
+      let active = 0
+      let maxActive = 0
+      const results = await scannerTuning.mapInBatches([0, 1, 2, 3, 4], 2, async (item) => {
+        active++
+        maxActive = Math.max(maxActive, active)
+        await new Promise((resolve) => setTimeout(resolve, 5))
+        active--
+        return item * 10
+      })
+
+      expect(maxActive).to.equal(2)
+      expect(results).to.deep.equal([0, 10, 20, 30, 40])
+    })
+  })
+})
