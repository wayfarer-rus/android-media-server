diff --git a/server/utils/scannerTuning.js b/server/utils/scannerTuning.js
new file mode 100644
index 00000000..aa880021
--- /dev/null
+++ b/server/utils/scannerTuning.js
@@ -0,0 +1,56 @@
+function parseIntegerEnv(name, defaultValue, minValue = 0, maxValue = Number.MAX_SAFE_INTEGER) {
+  const raw = process.env[name]
+  if (raw === undefined || raw === '') return defaultValue
+
+  const value = Number(raw)
+  if (!Number.isInteger(value) || value < minValue || value > maxValue) return defaultValue
+  return value
+}
+
+function getAudioProbeConcurrency() {
+  return parseIntegerEnv('ABS_SCAN_AUDIO_PROBE_CONCURRENCY', 32, 1, 1024)
+}
+
+function getAudioProbeBatchDelayMs() {
+  return parseIntegerEnv('ABS_SCAN_AUDIO_PROBE_BATCH_DELAY_MS', 0, 0, 60000)
+}
+
+function getLibraryFileConcurrency() {
+  return parseIntegerEnv('ABS_SCAN_LIBRARY_FILE_CONCURRENCY', 0, 0, 1024)
+}
+
+function getLibraryFileBatchDelayMs() {
+  return parseIntegerEnv('ABS_SCAN_LIBRARY_FILE_BATCH_DELAY_MS', 0, 0, 60000)
+}
+
+function delay(ms) {
+  return new Promise((resolve) => setTimeout(resolve, ms))
+}
+
+async function mapInBatches(items, batchSize, mapper, batchDelayMs = 0) {
+  if (!items.length) return []
+
+  if (!batchSize || batchSize >= items.length) {
+    return Promise.all(items.map(mapper))
+  }
+
+  const results = []
+  for (let start = 0; start < items.length; start += batchSize) {
+    const batch = items.slice(start, start + batchSize)
+    results.push(...(await Promise.all(batch.map(mapper))))
+
+    if (batchDelayMs && start + batchSize < items.length) {
+      await delay(batchDelayMs)
+    }
+  }
+  return results
+}
+
+module.exports = {
+  parseIntegerEnv,
+  getAudioProbeConcurrency,
+  getAudioProbeBatchDelayMs,
+  getLibraryFileConcurrency,
+  getLibraryFileBatchDelayMs,
+  mapInBatches
+}
diff --git a/test/server/scanner/AudioFileScanner.test.js b/test/server/scanner/AudioFileScanner.test.js
